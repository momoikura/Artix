{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Artix runs fully offline. It may open native file dialogs and read/write files the user explicitly picks, plus its own app-data directory.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-set-title",
    "core:webview:allow-internal-toggle-devtools",
    "dialog:default",
    "opener:allow-open-path",
    "opener:allow-open-url",
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [{ "path": "$APPDATA/**" }, { "path": "$HOME/**" }]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [{ "path": "$APPDATA/**" }]
    },
    {
      "identifier": "fs:allow-read-dir",
      "allow": [{ "path": "$APPDATA/**" }, { "path": "$HOME/**" }]
    },
    "fs:allow-app-meta-recursive"
  ]
}
