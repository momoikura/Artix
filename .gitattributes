# Normalise line endings so a Windows clone and a Linux clone produce identical
# diffs. Without this, CRLF checkouts show every file as modified on Linux CI.
* text=auto eol=lf

# Windows-only scripts must keep CRLF or cmd.exe mis-parses them.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary — never diff or normalise.
*.png binary
*.ico binary
*.icns binary
*.jpg binary
*.zip binary
*.db binary

# Lockfiles are generated; collapse them in PR reviews.
package-lock.json linguist-generated=true -diff
src-tauri/Cargo.lock linguist-generated=true -diff

# Report the language mix honestly on the repo page.
docs/* linguist-documentation
*.glsl.ts linguist-language=GLSL
